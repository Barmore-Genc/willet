{
  "name": "@willet/api-spec",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openapi.json"
  ],
  "scripts": {
    "gen": "openapi-typescript src/openapi.json -o src/schema.ts",
    "build": "pnpm run gen && tsc && cp src/openapi.json dist/openapi.json",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "openapi-typescript": "^7.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
