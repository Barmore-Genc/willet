{
  "name": "@willet/mcp",
  "version": "0.0.0",
  "description": "Willet MCP server — local stdio transport",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "willet-mcp": "bin/willet-mcp.js",
    "willet-export": "bin/willet-export.js",
    "willet-import": "bin/willet-import.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeriousBug/willet.git"
  },
  "homepage": "https://github.com/SeriousBug/willet",
  "bugs": {
    "url": "https://github.com/SeriousBug/willet/issues"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "clean": "rm -rf dist",
    "check": "tsc --noEmit",
    "build": "node build.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "better-sqlite3": "^12.8.0",
    "onnxruntime-node": "^1.24.3",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@modelcontextprotocol/ext-apps": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@willet/shared": "workspace:*",
    "archiver": "^7.0.0",
    "esbuild": "^0.25.0",
    "node-stream-zip": "^1.15.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "ulid": "^3.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
