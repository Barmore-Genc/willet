{
  "name": "willet",
  "version": "1.0.0",
  "private": true,
  "description": "A local-first task tracking MCP server for AI agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeriousBug/willet.git"
  },
  "homepage": "https://github.com/SeriousBug/willet",
  "bugs": {
    "url": "https://github.com/SeriousBug/willet/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "check": "pnpm -r run check",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node"
    ],
    "overrides": {
      "@huggingface/transformers>onnxruntime-web": "npm:empty-npm-package@1.0.0",
      "@huggingface/transformers>sharp": "npm:empty-npm-package@1.0.0"
    }
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
